# Copier ce fichier vers credentials.auto.tfvars et remplir avec les vraies valeurs
# NE JAMAIS commiter credentials.auto.tfvars dans Git !

# URL de l'API Proxmox (remplacer par l'IP de votre serveur Proxmox)
proxmox_api_url = "https://192.168.1.XXX:8006/api2/json"

# Token API Proxmox
proxmox_api_token_id = "root@pam!terraform"
proxmox_api_token    = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Clé SSH publique par défaut pour l'accès initial aux VMs
default_ssh_pub_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
